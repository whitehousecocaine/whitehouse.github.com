                <ul>
                    <li>Educate yourself about risks</li>
                    <li>Avoid peer pressure situations</li>
                    <li>Promote healthy lifestyle choices</li>
                    <li>Encourage open conversations</li>
                </ul>
            </div>
            <div class="col-md-6">
                <h5>Support Options</h5>
                <ul>
                    <li>Professional counseling</li>
                    <li>Rehabilitation programs</li>
                    <li>Support groups</li>
                    <li>Medical assistance</li>
                </ul>
            </div>
        </div>
    </div>
</section>

